root = true

# Global rules for EVERYTHING in this folder
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# JSON is usually better at 2 spaces for readability
[*.json]
indent_size = 2

# Keep your ignore rule for the terminal exec script
[xdg-terminal-exec]
ignore = true
